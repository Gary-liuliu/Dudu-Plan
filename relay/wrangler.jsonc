{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dudu-plan-relay",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "RelayRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RelayRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
